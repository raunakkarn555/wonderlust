<% layout('/layouts/boilerplate') %>

    <div class="row mt-3">
        <div class="col-6 offset-3">
            <h3>SignUp on WonderLust</h3>
            <form action="/signup" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                  <label for="username" class="form-label">Username </label>
                  <input type="text" name="username" id="username" placeholder="eg: raunakkarn555" required class="form-control">
                  <div class="valid-feedback">Looks good!</div>
                  <div class="invalid-feedback">Write a suitable username.</div>
                </div>

                <div class="mb-3">
                  <label for="email" class="form-label">Email </label>
                  <input type="email" name="email" id="email" placeholder="eg: abc@gmail.com" required class="form-control">
                  <div class="valid-feedback">Looks good!</div>
                  <div class="invalid-feedback">Write a correct emailId.</div>    
                </div>
                
                <div class="mb-3">
                  <label for="password" class="form-label">Password </label>
                  <input type="password" name="password" id="password" required class="form-control">
                  <div class="valid-feedback">Looks good!</div>
                  <div class="invalid-feedback">Write a strong paassword.</div>    
                </div>     

                <button class="btn btn-success">SignUp</button>
            </form>
        </div>
    </div>