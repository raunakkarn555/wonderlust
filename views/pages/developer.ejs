<% layout("/layouts/boilerplate") %>

<style>
:root {
    --primary-color: #fe424d;
    --dark-color: #1a1a1a;
    --light-bg: #f9f9f9;
    --border-color: #eef0f2;
}

* { box-sizing: border-box; }

.dev-container {
    max-width: 1150px;
    margin: 4rem auto;
    padding: 0 1.5rem;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    color: #333;
    line-height: 1.6;
    overflow-wrap: break-word;
}

/* Hero & Buttons */
.profile-hero {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 3.5rem;
    align-items: center;
    border-bottom: 2px solid var(--border-color);
    padding-bottom: 3rem;
    margin-bottom: 3.5rem;
}

.dev-photo {
    width: 250px;
    height: 250px;
    border-radius: 16px;
    object-fit: cover;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
}

.hero-info h1 { font-size: 2.8rem; color: var(--dark-color); margin: 0 0 0.5rem 0; font-weight: 800; }
.tagline { font-size: 1.25rem; color: var(--primary-color); font-weight: 600; margin-bottom: 1.2rem; }

.cta-btn {
    display: inline-block;
    background: var(--primary-color);
    color: white;
    padding: 0.8rem 1.8rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    margin-top: 1rem;
    transition: opacity 0.2s;
}
.cta-btn:hover { opacity: 0.9; color: white; }

/* Sections */
.main-layout { display: grid; grid-template-columns: 2.2fr 1fr; gap: 3.5rem; }
.dev-section { margin-bottom: 3rem; }
.dev-section h2 { font-size: 1.8rem; color: var(--dark-color); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; }
.dev-section h2 i { color: var(--primary-color); }

/* Project Cards */
.projects-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.project-card { background: #fff; border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
.project-tag { display: inline-block; background: #ffebeb; color: var(--primary-color); font-size: 0.7rem; font-weight: bold; padding: 0.2rem 0.5rem; border-radius: 4px; text-transform: uppercase; margin-bottom: 0.5rem; }
.ai-tag { background: #e8f0fe; color: #1a73e8; }

/* Sidebar */
.sidebar-box { background: var(--light-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; position: sticky; top: 6rem; }
.link-list { list-style: none; padding: 0; }
.link-list li { margin-bottom: 1rem; }
.link-list a { display: flex; align-items: center; gap: 0.75rem; color: #444; text-decoration: none; }

/* ===================== RESPONSIVE (TABLET / MOBILE) ===================== */

@media (max-width: 991px) {
    .dev-container {
        margin: 2.5rem auto;
        padding: 0 1.2rem;
    }

    .profile-hero {
        grid-template-columns: 200px 1fr;
        gap: 2rem;
        padding-bottom: 2rem;
        margin-bottom: 2.5rem;
    }

    .dev-photo {
        width: 180px;
        height: 180px;
    }

    .hero-info h1 { font-size: 2.2rem; }
    .tagline { font-size: 1.1rem; }

    .main-layout {
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }

    .sidebar-box {
        position: static;
        top: auto;
    }

    .link-list a { padding: 0.4rem 0; }
}

@media (max-width: 600px) {
    .dev-container {
        margin: 1.5rem auto;
        padding: 0 1rem;
    }

    .profile-hero {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 1.2rem;
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
    }

    .profile-photo-wrapper {
        display: flex;
        justify-content: center;
    }

    .dev-photo {
        width: 150px;
        height: 150px;
    }

    .hero-info h1 { font-size: 1.8rem; margin-bottom: 0.4rem; }
    .tagline { font-size: 1rem; margin-bottom: 1rem; }

    /* keep heading/tagline centered, but body text left-aligned for readability */
    .hero-bio {
        text-align: left;
        font-size: 0.95rem;
    }

    .cta-btn {
        width: 100%;
        text-align: center;
        padding: 0.9rem 1.5rem;
        margin-top: 0.5rem;
    }

    .dev-section { margin-bottom: 2.2rem; }
    .dev-section h2 { font-size: 1.35rem; gap: 0.5rem; }

    .projects-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .project-card { padding: 1.2rem; }
    .project-card h3 { font-size: 1.05rem; margin: 0.3rem 0; }
    .project-card p { font-size: 0.9rem; }

    .sidebar-box { padding: 1.5rem; }

    .link-list li { margin-bottom: 0.3rem; }
    .link-list a {
        padding: 0.5rem 0.2rem;
        font-size: 0.95rem;
    }
}

@media (max-width: 400px) {
    .hero-info h1 { font-size: 1.5rem; }
    .tagline { font-size: 0.9rem; }
    .dev-photo { width: 120px; height: 120px; }
    .dev-section h2 { font-size: 1.2rem; }
}
</style>

